%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#ffffff', 'edgeLabelBackground':'#ffffff', 'tertiaryColor': '#ffffff'}}}%%
classDiagram
    direction LR

    %% ====================
    %% Classes de base (Utilisateurs)
    %% ====================
    class Utilisateur {
        +int id
        +string nom
        +string email
        +string mot_de_passe
        +datetime date_creation
        +connexion()
    }

    class Etudiant {
        +string telephone
        +string ville
        +string filiere
        +string diplome
        +string bio
        +string github
        +string linkedin
        +ajouter_favoris()
        +postuler_stage()
    }

    class Entreprise {
        +string nom_entreprise
        +string secteur
        +string ville
        +string adresse
        +string telephone
        +ajouter_offre()
        +gerer_offres()
    }

    class Administrateur {
        +gerer_comptes()
        +moderation_offres()
        +voir_statistiques()
    }

    %% ====================
    %% Entités Métier
    %% ====================
    class Offre {
        +int id
        +string titre
        +string description
        +date date_debut
        +date date_fin
        +int entreprise_id
    }

    class Candidature {
        +int id
        +int etudiant_id
        +int offre_id
        +string statut
        +datetime date_postulation
    }

    class DocumentCV {
        +int id
        +string image_path
        +datetime date_upload
    }

    class Commentaire {
        +int id
        +int utilisateur_id
        +string texte
        +datetime date_creation
    }

    class Favoris {
        +int id
        +int etudiant_id
        +int offre_id
    }

    class Role {
        +int id
        +string nom
    }

    class Permission {
        +int id
        +string nom
    }

    %% ====================
    %% Héritage (Direction maintenue pour la cohérence)
    %% ====================
    Utilisateur <|-- Etudiant
    Utilisateur <|-- Entreprise
    Utilisateur <|-- Administrateur

    %% ====================
    %% Relations & Cardinalités
    %% ====================
    
    Utilisateur "1" -- "n" Role : possède
    Role "1" -- "n" Permission : contient
    
    Etudiant "1" -- "n" Candidature : postule
    Etudiant "1" -- "n" Favoris : ajoute
    Etudiant "1" -- "n" Commentaire : écrit

    Entreprise "1" -- "n" Offre : publie
    Entreprise "1" -- "n" Candidature : reçoit
    Entreprise "1" -- "n" Commentaire : écrit

    Offre "1" -- "n" Candidature : concerne
    Offre "1" -- "n" Favoris : est ciblé par
    
    Administrateur "1" -- "n" Commentaire : modère

    Candidature "1" -- "1" DocumentCV : possède