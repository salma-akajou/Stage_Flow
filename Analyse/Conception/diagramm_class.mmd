classDiagram
%% Diagramme de classes StageFlow 

%% ====================
%% Utilisateurs
%% ====================
class Utilisateur {
    +id : int
    +nom : string
    +email : string
    +mot_de_passe : string
    +date_creation : datetime
    +connexion()
}

class Etudiant {
    +telephone : string
    +ville : string
    +filiere : string
    +diplome : string
    +bio : string
    +github : string
    +linkedin : string
    +ajouter_favoris(offre : Offre)
    +postuler_stage(offre : Offre, cv : string)
    +suivre_candidatures()
}

class Entreprise {
    +nom_entreprise : string
    +secteur : string
    +ville : string
    +adresse : string
    +description : string
    +site_web : string
    +telephone : string
    +ajouter_offre(offre : Offre)
    +gerer_offres()
    +consulter_candidatures()
    +gerer_candidatures()
}

class Administrateur {
    +gerer_comptes()
    +moderation_offres()
    +moderation_commentaires()
    +voir_statistiques()
}

%% ====================
%% Stage / Offre
%% ====================
class Offre {
    +id : int
    +titre : string
    +description : string
    +date_debut : date
    +date_fin : date
    +entreprise_id : int
}

class Candidature {
    +id : int
    +etudiant_id : int
    +offre_id : int
    +cv : string
    +statut : string
    +date_postulation : datetime
}

class Favoris {
    +id : int
    +etudiant_id : int
    +offre_id : int
    +date_ajout : datetime
}

class Commentaire {
    +id : int
    +utilisateur_id : int
    +texte : string
    +date_creation : datetime
}

class Notification {
    +id : int
    +utilisateur_id : int
    +message : string
    +lu : bool
    +date_creation : datetime
}

%% ====================
%% Relations principales
%% ====================
Utilisateur <|-- Etudiant
Utilisateur <|-- Entreprise
Utilisateur <|-- Administrateur

Etudiant "1" --> "*" Candidature : postule
Etudiant "1" --> "*" Favoris : ajoute
Etudiant "1" --> "*" Commentaire : écrit

Entreprise "1" --> "*" Offre : publie
Entreprise "1" --> "*" Commentaire : écrit
Entreprise "1" --> "*" Candidature : reçoit

Administrateur "1" --> "*" Commentaire : modère

Utilisateur "1" --> "*" Notification : reçoit

%% Relation Favoris - Offre
Offre "1" --> "*" Favoris : contient

%% ====================
%% Spatie Roles / Permissions
%% ====================
class Role {
    +id : int
    +nom : string
    +description : string
}

class Permission {
    +id : int
    +nom : string
    +description : string
}

Utilisateur "*" --> "*" Role : possède
Role "*" --> "*" Permission : contient