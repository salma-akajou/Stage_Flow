%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#ffffff', 'edgeLabelBackground':'#ffffff', 'tertiaryColor': '#ffffff'}}}%%
classDiagram
    direction LR

    %% ====================
    %% Classes de base (Utilisateurs)
    %% ====================
    class Utilisateur {
        +int id
        +string prenom
        +string nom
        +string email
        +string password
        +enum statut
        +datetime created_at
    }

    class Etudiant {
        +enum etablissement
        +string filiere
        +enum niveau_etudes
        +string photo
        +text bio
        +string github
        +string linkedin
        +int vues
    }

    class Entreprise {
        +string nom_entreprise
        +enum secteur
        +string adresse
        +string email_contact
        +text bio
        +string registre_commerce
        +string logo
        +enum taille
        +int vues
    }

    class Administrateur {
        +gerer_comptes()
        +moderer_feedbacks()
        +voir_statistiques()
    }

    %% ====================
    %% Entités Métier
    %% ====================
    class Offre {
        +int id
        +string titre
        +text description
        +enum type_stage
        +string duree
        +enum remuneration
        +enum format
        +enum secteur
        +text responsabilites
        +text profil_recherche
        +json competences_techniques
        +enum status
        +datetime date_publication
        +date date_debut
        +date date_fin
    }

    class Candidature {
        +int id
        +enum statut
        +string telephone
        +text message_motivation
        +datetime created_at
    }

    class DocumentCV {
        +int id
        +string file_path
        +datetime created_at
    }

    class Feedback {
        +int id
        +text texte
        +int note
        +boolean valide
        +datetime created_at
    }

    class Favoris {
        +int id
        +datetime created_at
    }

    class Ville {
        +int id
        +string nom
    }

    class Notification {
        +int id
        +enum type
        +string title
        +string message
        +json data
        +datetime read_at
        +datetime created_at
    }

    %% ====================
    %% Héritage (Logique)
    %% ====================
    Utilisateur <|-- Etudiant
    Utilisateur <|-- Entreprise
    Utilisateur <|-- Administrateur

    %% ====================
    %% Relations & Cardinalités
    %% ====================
    
    Ville "1" -- "*" Etudiant : réside
    Ville "1" -- "*" Entreprise : située
    Ville "1" -- "*" Offre : localisée

    Etudiant "1" -- "*" Candidature : postule
    Etudiant "1" -- "*" Favoris : ajoute
    Etudiant "1" -- "*" DocumentCV : possède
    Etudiant "1" -- "0..*" Feedback : écrit
    
    Entreprise "1" -- "0..*" Feedback : écrit
    Entreprise "1" -- "*" Offre : publie
    
    Offre "1" -- "*" Candidature : concerne
    Offre "1" -- "*" Favoris : est ciblé par
    
    Administrateur "1" -- "*" Feedback : modère

    Candidature "1" -- "1" DocumentCV : utilise

    Etudiant "1" -- "0..*" Notification : est notifié
    Entreprise "1" -- "0..*" Notification : est notifiée
